#!/usr/bin/env bash
# committer — stage specific files and commit with a message
# Usage: committer "commit message" file1 [file2 ...]
# Enforces: non-empty message, at least one file

set -euo pipefail

usage() {
  printf 'Usage: %s "commit message" file1 [file2 ...]\n' "$(basename "$0")" >&2
  exit 2
}

[[ "$#" -lt 2 ]] && usage

message="$1"
shift

[[ -z "$message" ]] && { echo "Error: commit message cannot be empty" >&2; exit 1; }

# Validate Conventional Commits format
# Expected: type(scope)?: description  e.g. feat(auth): add login
cc_pattern='^(feat|fix|docs|refactor|style|perf|test|chore|wip|remove|security)(\(.+\))?: .+'
if ! echo "$message" | grep -qE "$cc_pattern"; then
  printf 'Error: commit message does not follow Conventional Commits format.\n' >&2
  printf '  Expected: type(scope)?: description\n' >&2
  printf '  Types: feat fix docs refactor style perf test chore wip remove security\n' >&2
  printf '  Example: feat(auth): add login flow\n' >&2
  if [ -t 0 ]; then
    # Interactive (human) — allow override with confirmation
    printf 'Proceed anyway? [y/N] ' >&2
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted." >&2; exit 1; }
  else
    # Non-interactive (agent) — hard fail so the agent fixes the message
    exit 1
  fi
fi

# Stage only the listed files
git add -- "$@"

# Check something is staged
if git diff --cached --quiet; then
  echo "Error: nothing staged after adding listed files" >&2
  exit 1
fi

git commit -m "$message"

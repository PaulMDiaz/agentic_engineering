#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
HOME_DIR="${HOME:-$(eval echo "~$(id -un)")}"
SRC="$ROOT_DIR/skills"
DST="$HOME_DIR/.cursor/skills"

[ -d "$HOME_DIR/.cursor" ] || exit 0

mkdir -p "$DST"

for skill_dir in "$SRC"/*; do
  [ -d "$skill_dir" ] || continue
  [ -f "$skill_dir/SKILL.md" ] || continue
  skill="$(basename "$skill_dir")"
  [ -e "$DST/$skill" ] || ln -s "$skill_dir" "$DST/$skill"
done
